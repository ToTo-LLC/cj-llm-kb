# Vault secrets must NEVER land in the repo (defense in depth;
# the real vault is at ~/Documents/brain/, not here)
**/.brain/secrets.env
**/.brain/logs/
**/.brain/run/
**/.brain/costs.sqlite
**/.brain/state.sqlite

# Broader secret/log safety net (catches stray .env files at any level)
.env
.env.*
!.env.example
*.log
